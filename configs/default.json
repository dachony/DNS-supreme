{
  "dns": {
    "listen_addr": "0.0.0.0",
    "port": 53,
    "forwarders": ["8.8.8.8:53", "1.1.1.1:53"],
    "cache_size": 10000
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "user": "dnsupreme",
    "password": "dnsupreme",
    "dbname": "dnsupreme",
    "sslmode": "disable"
  },
  "api": {
    "listen_addr": "0.0.0.0",
    "port": 5380,
    "https_port": 53443
  },
  "block_page": {
    "listen_addr": "0.0.0.0",
    "http_port": 80,
    "https_port": 443
  },
  "logging": {
    "query_log": true,
    "retention_days": 30,
    "batch_size": 100,
    "flush_interval_seconds": 5
  }
}
